apiVersion: v1
kind: Pod
metadata:
  name: jenkins-deployment
  labels:
    app: jenkins
spec:
  securityContext:
    fsGroup: 1000
  containers:
  - name: jenkins-container
    image: jenkins/jenkins:lts
    ports:
    - containerPort: 8080
    - containerPort: 50000
    env:
    - name: JENKINS_OPTS
      value: "--argumentsRealm.passwd.admin=admin --argumentsRealm.roles.admin=admin"
    volumeMounts:
    - name: jenkins-home
      mountPath: /var/jenkins_home
  volumes:
  - name: jenkins-home
    emptyDir: {}

# 1. सभी servers पर basic setup (Master + Worker)

sudo hostnamectl set-hostname master-node   # worker पर worker-node1 आदि

sudo apt update && sudo apt upgrade -y

# swap disable
sudo swapoff -a
sudo sed -i '/ swap / s/^/#/' /etc/fstab

# kernel modules
cat <<EOF | sudo tee /etc/modules-load.d/k8s.conf
overlay
br_netfilter
EOF

sudo modprobe overlay
sudo modprobe br_netfilter

# sysctl settings
cat <<EOF | sudo tee /etc/sysctl.d/k8s.conf
net.bridge.bridge-nf-call-iptables = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward = 1
EOF

sudo sysctl --system


# 2.  Container Runtime install (containerd)
2️sudo apt install -y containerd

sudo mkdir -p /etc/containerd

containerd config default | sudo tee /etc/containerd/config.toml

sudo systemctl restart containerd
sudo systemctl enable containerd


# 3.Kubernetes packages install
sudo apt update
sudo apt install -y apt-transport-https ca-certificates curl

curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.29/deb/Release.key | \
sudo gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg

echo 'deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] \
https://pkgs.k8s.io/core:/stable:/v1.29/deb/ /' | \
sudo tee /etc/apt/sources.list.d/kubernetes.list

sudo apt update

sudo apt install -y kubelet kubeadm kubectl

sudo apt-mark hold kubelet kubeadm kubectl



# 4. Master Node Initialize
sudo kubeadm init --pod-network-cidr=192.168.0.0/16



#5. kubectl configure (Master पर)

mkdir -p $HOME/.kube

sudo cp -i /etc/kubernetes/admin.conf $HOME/.kube/config

sudo chown $(id -u):$(id -g) $HOME/.kube/config
kubectl get nodes

# 6. Network Plugin install (Calico)
kubectl apply -f https://raw.githubusercontent.com/projectcalico/calico/v3.27.0/manifests/calico.yaml



# 7. Worker Node Join
sudo kubeadm join 192.168.1.10:6443 \
--token abcdef.123456789 \
--discovery-token-ca-cert-hash sha256:xxxxxxxx

# 8. Cluster check
kubectl get nodes

kubectl get pods -A


# 9. Test Deployment
kubectl create deployment nginx --image=nginx

kubectl expose deployment nginx --type=NodePort --port=80

kubectl get svc

# 10.Important Debug Commands
kubectl get nodes
kubectl get pods -A
kubectl describe node
kubectl logs pod-name
kubectl get svc